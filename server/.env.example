# Server listen port
PORT=5219

# Shared secret the client must send as `Authorization: Bearer <token>`
AUTH_TOKEN=change-me-to-a-long-random-string

# Command used to invoke the GitHub Copilot CLI (must be authenticated: `copilot login`)
COPILOT_COMMAND=copilot

# Optional: force a specific model (leave empty to let the CLI choose)
COPILOT_MODEL=

# Directory the Copilot agent operates in (file edits/shell commands run here).
# Defaults to ./workspace next to the server if left empty. Use an absolute path to point elsewhere.
WORK_DIR=

# Comma-separated allow-list of folders a client may pick as a new session's working directory
# (via the New Chat folder picker / git-clone flow), and the boundary used to filter which past
# CLI sessions show up in the Sessions list. Defaults to just WORK_DIR if left empty - NOT your
# home directory, since that would surface every Copilot CLI session ever run on this machine
# (including unrelated tools) in this app's Sessions list. Example:
# BROWSE_ROOTS=/Users/you/repos,/Volumes/data/projects
BROWSE_ROOTS=

# EXPERIMENTAL: push a notification via ntfy (https://ntfy.sh) whenever a chat turn finishes, so
# you find out Copilot replied without keeping the client app open. Leave empty to disable (default).
# Install the free "ntfy" app (App Store/Play Store), subscribe to this exact topic name there, and
# set it here too. Treat the topic name like a password - anyone who knows it can publish to/read
# it on the public ntfy.sh server, so pick a long random string, e.g.: openssl rand -hex 16
NTFY_TOPIC=

# ntfy server to publish to - defaults to the public https://ntfy.sh if left empty. Override to
# point at a self-hosted ntfy instance instead.
NTFY_SERVER=

# PBI-026: other Copilot chat servers (different machines/OS) this one can dispatch cross-server
# spawn_session requests to - a small, fixed set of machines you personally own/trust, not general
# internet peer discovery. JSON array of {name, url, token} - "token" is the PEER's own AUTH_TOKEN
# (not this server's). Leave empty/unset to disable (spawn_session/sessions:spawn stay local-only).
# Example:
# PEER_SERVERS=[{"name":"windows-pc","url":"ws://192.168.1.50:5219","token":"<that server's AUTH_TOKEN>"}]
PEER_SERVERS=

BROWSE_ROOTS=
