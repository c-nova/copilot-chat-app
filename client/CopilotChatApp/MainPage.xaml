<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="CopilotChatApp.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:CopilotChatApp.Models"
    xmlns:idk="clr-namespace:Indiko.Maui.Controls.Markdown;assembly=Indiko.Maui.Controls.Markdown"
    Title="GitHub Copilot CLI-GUI">

    <Shell.TitleView>
        <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
            <Image Source="app_logo.png"
                   WidthRequest="26"
                   HeightRequest="26"
                   VerticalOptions="Center" />
            <Label Text="GitHub Copilot CLI-GUI"
                   FontSize="20"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource SecondaryDarkText}}" />
        </HorizontalStackLayout>
    </Shell.TitleView>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="🔍" Order="Primary" Priority="0" Clicked="OnToggleSearchClicked" />
        <ToolbarItem Text="New chat" Order="Primary" Priority="1" Clicked="OnNewChatClicked" />
        <ToolbarItem Text="Settings" Order="Primary" Priority="2" Clicked="OnSettingsClicked" />
    </ContentPage.ToolbarItems>

    <Grid>
        <Grid RowDefinitions="Auto,*,Auto,Auto,Auto" Padding="0">

            <!-- In-chat "find" bar (PBI follow-up: search inside the current conversation, not just
                 across sessions - see HomePage's server-side search for that). Pure client-side
                 substring match over the already-loaded Messages list; no server round-trip needed
                 since the whole conversation is already in memory. -->
            <Grid x:Name="SearchBarRow"
                  Grid.Row="0"
                  IsVisible="False"
                  ColumnDefinitions="*,Auto,Auto,Auto"
                  ColumnSpacing="6"
                  Padding="8,6"
                  BackgroundColor="{AppThemeBinding Light=#F2F2F7, Dark={StaticResource Gray900}}">
                <SearchBar x:Name="ChatSearchBar"
                           Grid.Column="0"
                           Placeholder="この会話内を検索"
                           TextChanged="OnChatSearchTextChanged" />
                <Label x:Name="SearchCounterLabel"
                       Grid.Column="1"
                       Text="0/0"
                       VerticalOptions="Center"
                       TextColor="Gray"
                       FontSize="14" />
                <Button Grid.Column="2" Text="↑" WidthRequest="40" Clicked="OnSearchPrevClicked" />
                <Button Grid.Column="3" Text="↓" WidthRequest="40" Clicked="OnSearchNextClicked" />
            </Grid>

            <CollectionView x:Name="MessagesView"
                            Grid.Row="1"
                            Margin="8"
                            ItemsUpdatingScrollMode="KeepScrollOffset"
                            ItemSizingStrategy="MeasureAllItems"
                            ItemsSource="{Binding Messages}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ChatMessage">
                        <Grid Padding="4" RowDefinitions="Auto,Auto">
                            <Frame Padding="10,8"
                                   Grid.Row="0"
                                   CornerRadius="12"
                                   HasShadow="False"
                                   IsClippedToBounds="False"
                                   BorderColor="{Binding IsSearchHighlighted, Converter={StaticResource BoolToSearchHighlightBorderConverter}}"
                                   IsVisible="{Binding IsTool, Converter={StaticResource InvertedBoolConverter}}"
                                   BackgroundColor="{Binding ., Converter={StaticResource MessageToBubbleColorConverter}}"
                                   HorizontalOptions="{Binding IsUser, Converter={StaticResource BoolToAlignConverter}}"
                                   MaximumWidthRequest="{Binding Source={x:Reference MessagesView}, Path=Width, Converter={StaticResource WidthToBubbleMaxWidthConverter}}">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnMessageTapped" />
                                </Frame.GestureRecognizers>
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="🤖 Message from other Agent"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="#8B5E00"
                                           IsVisible="{Binding IsFromOtherSession}" />
                                    <CollectionView ItemsSource="{Binding Attachments}"
                                                    IsVisible="{Binding HasAttachments}"
                                                    HeightRequest="72"
                                                    HorizontalOptions="Start">
                                        <CollectionView.ItemsLayout>
                                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="6" />
                                        </CollectionView.ItemsLayout>
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="models:PendingAttachment">
                                                <Image Source="{Binding Preview}"
                                                       Aspect="AspectFill"
                                                       WidthRequest="64"
                                                       HeightRequest="64" />
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                    <idk:MarkdownView MarkdownText="{Binding Text}"
                                                       TextFontSize="{DynamicResource ChatFontSize}"
                                                       CodeBlockFontSize="{DynamicResource ChatFontSize}"
                                                       H1Color="#1A1A1A"
                                                       H2Color="#1A1A1A"
                                                       H3Color="#1A1A1A"
                                                       H4Color="#1A1A1A"
                                                       H5Color="#1A1A1A"
                                                       H6Color="#1A1A1A">
                                        <idk:MarkdownView.CodeBlockFontFace>
                                            <OnPlatform x:TypeArguments="x:String">
                                                <On Platform="iOS, MacCatalyst" Value="Courier" />
                                                <On Platform="WinUI" Value="Consolas" />
                                                <On Platform="Android" Value="monospace" />
                                            </OnPlatform>
                                        </idk:MarkdownView.CodeBlockFontFace>
                                    </idk:MarkdownView>
                                    <Label Text="✓ コピーしました"
                                           FontSize="11"
                                           TextColor="Gray"
                                           IsVisible="{Binding IsCopied}" />
                                    <!-- Extra bottom buffer scaled to the current chat font size AND the
                                         bubble's actual available width (see BubbleConverters.cs's
                                         MessageToBubbleBottomPaddingConverter) - MarkdownView's custom-drawn
                                         height calculation lands short on multi-line/tabular content, and
                                         how short depends on how much table-cell text actually wraps at the
                                         current width, not just a flat per-font-size amount. A Label (not
                                         BoxView) is used here deliberately - BoxView.Color defaults to
                                         opaque black and rendered as a visible black bar instead of
                                         Transparent on Mac Catalyst; Label has no separate fill color to
                                         fight with.
                                    -->
                                    <Label Text="" InputTransparent="True">
                                        <Label.HeightRequest>
                                            <MultiBinding Converter="{StaticResource MessageToBubbleBottomPaddingConverter}">
                                                <Binding Path="." />
                                                <Binding Source="{x:Reference MessagesView}" Path="Width" Converter="{StaticResource WidthToBubbleMaxWidthConverter}" />
                                            </MultiBinding>
                                        </Label.HeightRequest>
                                    </Label>
                                </VerticalStackLayout>
                            </Frame>
                            <Label Grid.Row="1"
                                   Text="🔎 テキスト選択"
                                   FontSize="14"
                                   Opacity="0.55"
                                   Margin="6,1,6,0"
                                   IsVisible="{Binding IsTool, Converter={StaticResource InvertedBoolConverter}}"
                                   HorizontalOptions="{Binding IsUser, Converter={StaticResource BoolToAlignConverter}}">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSelectTextTapped" />
                                </Label.GestureRecognizers>
                            </Label>
                            <HorizontalStackLayout Grid.Row="0"
                                                    IsVisible="{Binding IsTool}"
                                                   HorizontalOptions="Center"
                                                   Spacing="6">
                                <ActivityIndicator IsRunning="{Binding IsRunning}"
                                                    IsVisible="{Binding IsRunning}"
                                                    Color="Gray"
                                                    WidthRequest="14"
                                                    HeightRequest="14"
                                                    VerticalOptions="Center" />
                                <Label Text="{Binding Text}"
                                       FontSize="12"
                                       FontAttributes="Italic"
                                       TextColor="Gray"
                                       TextDecorations="Underline"
                                       VerticalOptions="Center"
                                       HorizontalTextAlignment="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnToolTapped" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </HorizontalStackLayout>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Sending status indicator: shown from the moment Send is tapped until the turn is fully
                 finalized (IsSending covers tool calls too, unlike IsWaitingForResponse which turns off
                 the instant *anything* visible happens - including a tool call starting - so relying on
                 that alone left the user unable to tell whether a multi-tool-call turn had actually
                 finished or was still working. See PBI-015). -->
            <HorizontalStackLayout Grid.Row="2"
                                   IsVisible="{Binding IsSending}"
                                   Spacing="6"
                                   Margin="12,0,12,4">
                <ActivityIndicator IsRunning="{Binding IsSending}"
                                   Color="Gray"
                                   WidthRequest="14"
                                   HeightRequest="14"
                                   VerticalOptions="Center" />
                <Label Text="Copilot is working…"
                       FontSize="16"
                       FontAttributes="Italic"
                       TextColor="Gray"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>

            <!-- Pending attachment strip: images pasted via the 📎 button, staged for the next
                 message and removable individually before Send (PBI-019). -->
            <CollectionView Grid.Row="3"
                            ItemsSource="{Binding PendingAttachments}"
                            IsVisible="{Binding HasPendingAttachments}"
                            HeightRequest="76"
                            Margin="8,4,8,0">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="6" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:PendingAttachment">
                        <Grid WidthRequest="64" HeightRequest="64">
                            <Image Source="{Binding Preview}" Aspect="AspectFill" WidthRequest="64" HeightRequest="64" />
                            <Label Text="✕"
                                   FontSize="12"
                                   TextColor="White"
                                   BackgroundColor="#88000000"
                                   HorizontalOptions="End"
                                   VerticalOptions="Start"
                                   WidthRequest="18"
                                   HeightRequest="18"
                                   HorizontalTextAlignment="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnRemoveAttachmentTapped" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Border Grid.Row="4"
                    Margin="8"
                    Padding="10,8"
                    StrokeShape="RoundRectangle 20"
                    Stroke="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray600}}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light=#F2F2F7, Dark={StaticResource Gray900}}">
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.10" Radius="10" Offset="0,2" />
                </Border.Shadow>
                <Grid RowDefinitions="Auto,Auto,Auto"
                      ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="8"
                      RowSpacing="4">
                    <Label Grid.Row="0"
                       Grid.Column="0"
                       Text="Model"
                       FontSize="12"
                       TextColor="Gray"
                       VerticalOptions="Center" />
                    <Picker x:Name="ChatModelPicker"
                        Grid.Row="0"
                        Grid.Column="1"
                        ItemDisplayBinding="{Binding DisplayName}"
                        SelectedIndexChanged="OnChatModelChanged"
                        VerticalOptions="Center" />
                    <Button x:Name="RefreshModelsButton"
                        Grid.Row="0"
                        Grid.Column="2"
                        Text="↻"
                        FontSize="20"
                        WidthRequest="44"
                        HeightRequest="36"
                        Padding="0"
                        Clicked="OnRefreshModelsClicked"
                        ToolTipProperties.Text="Reload models" />
                    <Label x:Name="ChatModelStatusLabel"
                       Grid.Row="1"
                       Grid.Column="0"
                       Grid.ColumnSpan="3"
                       FontSize="11"
                       TextColor="Gray"
                       IsVisible="False"
                       LineBreakMode="TailTruncation" />
                    <Button Grid.Row="2"
                        Grid.Column="0"
                            Text="📎"
                            Clicked="OnPasteImageClicked"
                            BackgroundColor="Transparent"
                            VerticalOptions="Center" />
                    <Editor x:Name="InputEditor"
                        Grid.Row="2"
                            Grid.Column="1"
                            Text="{Binding InputText}"
                            FontSize="{DynamicResource ChatFontSize}"
                            Placeholder="Message Copilot..."
                            BackgroundColor="Transparent"
                            AutoSize="TextChanges"
                            MinimumHeightRequest="96"
                            MaxLength="8000" />
                    <Button x:Name="SendButton"
                            Grid.Row="2"
                            Grid.Column="2"
                            Text="Send"
                            Command="{Binding SendCommand}"
                            VerticalOptions="Center" />
                </Grid>
            </Border>
        </Grid>

        <!-- Biometric lock overlay (PBI-009): shown while the SecureStorage-held auth token is gated
             behind Face ID / Touch ID / Windows Hello / device passcode. Hidden by default; only shown
             when EnsureUnlockedAsync() fails or the app resumes from background. -->
        <Grid x:Name="LockOverlay"
              IsVisible="{Binding IsLocked}"
              BackgroundColor="{AppThemeBinding Light=#E6FFFFFF, Dark=#E61A1A1A}">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="16">
                <Label Text="🔒" FontSize="48" HorizontalOptions="Center" />
                <Label Text="Locked" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" />
                <Label Text="Authenticate to continue" FontSize="13" Opacity="0.7" HorizontalOptions="Center" />
                <Button Text="Unlock" Command="{Binding UnlockCommand}" HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>

</ContentPage>
