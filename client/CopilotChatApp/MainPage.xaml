<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="CopilotChatApp.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:CopilotChatApp.Models"
    xmlns:idk="clr-namespace:Indiko.Maui.Controls.Markdown;assembly=Indiko.Maui.Controls.Markdown"
    Title="GitHub Copilot CLI/GUI">

    <Shell.TitleView>
        <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
            <Image Source="app_logo.png"
                   WidthRequest="26"
                   HeightRequest="26"
                   VerticalOptions="Center" />
            <Label Text="GitHub Copilot CLI/GUI"
                   FontSize="20"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource SecondaryDarkText}}" />
        </HorizontalStackLayout>
    </Shell.TitleView>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="☰" Order="Primary" Priority="0" Clicked="OnSessionsClicked" />
        <ToolbarItem Text="New chat" Order="Primary" Priority="1" Clicked="OnNewChatClicked" />
        <ToolbarItem Text="Settings" Order="Primary" Priority="2" Clicked="OnSettingsClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*,Auto" Padding="0">

        <CollectionView x:Name="MessagesView"
                        Grid.Row="0"
                        Margin="8"
                        ItemsUpdatingScrollMode="KeepLastItemInView"
                        ItemsSource="{Binding Messages}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ChatMessage">
                    <Grid Padding="4" RowDefinitions="Auto,Auto">
                        <Frame Padding="10,8"
                               Grid.Row="0"
                               CornerRadius="12"
                               HasShadow="False"
                               IsVisible="{Binding IsTool, Converter={StaticResource InvertedBoolConverter}}"
                               BackgroundColor="{Binding IsUser, Converter={StaticResource BoolToBubbleColorConverter}}"
                               HorizontalOptions="{Binding IsUser, Converter={StaticResource BoolToAlignConverter}}"
                               MaximumWidthRequest="{Binding Source={x:Reference MessagesView}, Path=Width, Converter={StaticResource WidthToBubbleMaxWidthConverter}}">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMessageTapped" />
                            </Frame.GestureRecognizers>
                            <VerticalStackLayout Spacing="2">
                                <idk:MarkdownView MarkdownText="{Binding Text}" />
                                <Label Text="✓ コピーしました"
                                       FontSize="11"
                                       TextColor="Gray"
                                       IsVisible="{Binding IsCopied}" />
                            </VerticalStackLayout>
                        </Frame>
                        <Label Grid.Row="1"
                               Text="🔎 全文選択"
                               FontSize="11"
                               Opacity="0.55"
                               Margin="6,1,6,0"
                               IsVisible="{Binding IsTool, Converter={StaticResource InvertedBoolConverter}}"
                               HorizontalOptions="{Binding IsUser, Converter={StaticResource BoolToAlignConverter}}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSelectTextTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                        <HorizontalStackLayout Grid.Row="0"
                                                IsVisible="{Binding IsTool}"
                                               HorizontalOptions="Center"
                                               Spacing="6">
                            <ActivityIndicator IsRunning="{Binding IsRunning}"
                                                IsVisible="{Binding IsRunning}"
                                                Color="Gray"
                                                WidthRequest="14"
                                                HeightRequest="14"
                                                VerticalOptions="Center" />
                            <Label Text="{Binding Text}"
                                   FontSize="12"
                                   FontAttributes="Italic"
                                   TextColor="Gray"
                                   TextDecorations="Underline"
                                   VerticalOptions="Center"
                                   HorizontalTextAlignment="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnToolTapped" />
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Padding="8" ColumnSpacing="8">
            <Editor x:Name="InputEditor"
                    Grid.Column="0"
                    Placeholder="Message Copilot..."
                    AutoSize="TextChanges"
                    MaxLength="8000" />
            <Button x:Name="SendButton"
                    Grid.Column="1"
                    Text="Send"
                    Clicked="OnSendClicked"
                    VerticalOptions="End" />
        </Grid>
    </Grid>

</ContentPage>
