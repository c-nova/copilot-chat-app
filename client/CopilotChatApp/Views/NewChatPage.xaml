<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="CopilotChatApp.Views.NewChatPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:services="clr-namespace:CopilotChatApp.Services"
    Title="New Chat">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Clone repo…" Clicked="OnCloneClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="16" RowSpacing="10">

        <VerticalStackLayout Grid.Row="0" Spacing="4">
            <Label x:Name="PathLabel"
                   FontSize="13"
                   TextColor="Gray"
                   LineBreakMode="TailTruncation" />
            <Label x:Name="BrowseRootsHintLabel"
                   Text="※ 現在はデフォルトのワークスペースのみ選択可能です。他のフォルダも選べるようにするには、server/.env で BROWSE_ROOTS を設定してサーバーを再起動してください。"
                   FontSize="12"
                   TextColor="{StaticResource Gray400}"
                   IsVisible="False" />
        </VerticalStackLayout>

        <HorizontalStackLayout Grid.Row="1" Spacing="8">
            <Button x:Name="UpButton" Text="⬆ 上へ" Clicked="OnUpClicked" IsVisible="False" FontSize="13" Padding="12,6" />
            <Button x:Name="RootsButton" Text="🏠 ルート一覧" Clicked="OnRootsClicked" IsVisible="False" FontSize="13" Padding="12,6" />
        </HorizontalStackLayout>

        <CollectionView x:Name="EntriesView"
                        Grid.Row="2"
                        ItemsSource="{Binding Entries}"
                        SelectionMode="None">
            <CollectionView.EmptyView>
                <VerticalStackLayout Spacing="6" Margin="0,20,0,0">
                    <Label Text="サブフォルダはありません。" TextColor="Gray" />
                    <Label Text="※ BROWSE_ROOTS 未設定の場合、デフォルトworkspace以外のフォルダは選べません。下の「デフォルトworkspaceを使う」で始めるか、server/.env で BROWSE_ROOTS を設定してください。"
                           FontSize="12"
                           TextColor="{StaticResource Gray400}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="services:FsEntry">
                    <Grid Padding="0,10">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnEntryTapped" CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>
                        <Label Text="{Binding Name, StringFormat='📁 {0}'}" FontSize="15" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <VerticalStackLayout Grid.Row="3" Spacing="8">
            <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                <Switch x:Name="OrchestratorSwitch" />
                <Label Text="🎼 Orchestratorとして開始(子セッションを操作できるAI)"
                       FontSize="13"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>
            <Button x:Name="UseCurrentFolderButton"
                    Text="✅ このフォルダで新規チャットを始める"
                    Clicked="OnUseCurrentFolderClicked"
                    IsVisible="False" />
            <Button Text="⚡ デフォルトworkspaceを使う"
                    Clicked="OnUseDefaultClicked"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
        </VerticalStackLayout>
    </Grid>

</ContentPage>
