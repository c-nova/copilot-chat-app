<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="CopilotChatApp.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Settings">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="サーバー" FontAttributes="Bold" FontSize="18" />
            <!-- Populated in code-behind (SettingsPage.xaml.cs LoadProfilesList) - a handful of rows
                 built manually is simpler here than a CollectionView inside a ScrollView (which has
                 its own known height/virtualization quirks on some platforms) since profile counts
                 are always small. Tap a row to edit it below; ✓ marks the currently active one. -->
            <VerticalStackLayout x:Name="ProfilesList" Spacing="8" />
            <Button Text="+ 新しいサーバーを追加" Clicked="OnAddProfileClicked" />

            <BoxView HeightRequest="1"
                     Margin="0,4"
                     BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />

            <Label x:Name="EditingProfileLabel" Text="編集中" FontAttributes="Bold" FontSize="16" />

            <Label Text="Name" FontAttributes="Bold" />
            <Entry x:Name="ProfileNameEntry" Placeholder="e.g. Mac mini" />

            <Label Text="Server URL" FontAttributes="Bold" Margin="0,12,0,0" />
            <Entry x:Name="ServerUrlEntry" Placeholder="ws://192.168.1.10:5219" Keyboard="Url" />
            <Label FontSize="12" TextColor="Gray"
                   Text="The address of the copilot-chat-server running on your PC/Mac. Use wss:// if the server is behind TLS." />

            <Label Text="Auth Token" FontAttributes="Bold" Margin="0,12,0,0" />
            <Entry x:Name="AuthTokenEntry" Placeholder="shared secret" IsPassword="True" />
            <Label FontSize="12" TextColor="Gray"
                   Text="Must match AUTH_TOKEN configured in the server's .env file." />

            <Label Text="Chat Font Size" FontAttributes="Bold" Margin="0,12,0,0" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Slider x:Name="FontSizeSlider"
                        Grid.Column="0"
                        Minimum="12" Maximum="28"
                        ValueChanged="OnFontSizeChanged" />
                <Label x:Name="FontSizeLabel"
                       Grid.Column="1"
                       WidthRequest="36"
                       VerticalOptions="Center"
                       HorizontalTextAlignment="End" />
            </Grid>
            <Label Text="Sample chat text" FontSize="{DynamicResource ChatFontSize}" />

            <Button x:Name="SaveButton" Text="Save" Clicked="OnSaveClicked" Margin="0,20,0,0" />
            <ActivityIndicator x:Name="ConnectingIndicator" IsVisible="False" IsRunning="False" Margin="0,4,0,0" />
            <Button Text="Manage MCP Servers" Clicked="OnMcpServersClicked" Margin="0,8,0,0" />
            <Button Text="Start New Conversation" Clicked="OnNewConversationClicked" BackgroundColor="Transparent" TextColor="Red" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
