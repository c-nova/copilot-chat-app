<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="CopilotChatApp.Views.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:services="clr-namespace:CopilotChatApp.Services"
    Title="Sessions">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="New chat" Order="Primary" Priority="0" Clicked="OnNewChatClicked" />
        <ToolbarItem Text="Settings" Order="Primary" Priority="1" Clicked="OnSettingsClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="16" RowSpacing="12">

        <!-- Server metadata chip: OS/hostname/CLI version/model, fetched best-effort via server:info. -->
        <Border Grid.Row="0"
                x:Name="ServerInfoBorder"
                IsVisible="False"
                StrokeShape="RoundRectangle 10"
                Stroke="Transparent"
                Padding="12,8"
                BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource Gray900}}">
            <Label x:Name="ServerInfoLabel"
                   FontSize="19"
                   TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource SecondaryDarkText}}"
                   LineBreakMode="TailTruncation" />
        </Border>

        <Label x:Name="NotConfiguredLabel"
               Grid.Row="1"
               Text="サーバーが未設定です。右上の Settings からサーバーURLとトークンを入力してください。"
               IsVisible="False"
               FontSize="20"
               TextColor="Gray"
               Margin="0,20,0,0" />

        <HorizontalStackLayout Grid.Row="2" Spacing="8">
            <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False" />
            <Label x:Name="LoadingLabel"
                   Text="Connecting to server… this can take up to 30s while waiting for network permission"
                   IsVisible="False"
                   VerticalOptions="Center"
                   FontSize="20"
                   TextColor="Gray" />
        </HorizontalStackLayout>

        <CollectionView x:Name="SessionsView"
                        Grid.Row="3"
                        ItemsSource="{Binding Sessions}"
                        SelectionMode="None">
            <CollectionView.EmptyView>
                <Label Text="過去のセッションはまだありません。「New chat」で始めましょう。" FontSize="20" TextColor="Gray" Margin="0,20,0,0" />
            </CollectionView.EmptyView>
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2" VerticalItemSpacing="12" HorizontalItemSpacing="12" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="services:SessionSummary">
                    <Border StrokeShape="RoundRectangle 14"
                            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                            StrokeThickness="1"
                            Padding="14,12"
                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.08" Radius="8" Offset="0,3" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSessionTapped" CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <HorizontalStackLayout Spacing="6" IsVisible="{Binding Archived}">
                                <Label Text="📦 Archived" FontSize="17" TextColor="{StaticResource Gray400}" />
                            </HorizontalStackLayout>
                            <Label Text="{Binding DisplayTitle}"
                                   FontAttributes="Bold"
                                   FontSize="21"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="2" />
                            <Label Text="{Binding FolderName, StringFormat='📁 {0}'}"
                                   FontSize="17"
                                   TextColor="{StaticResource Gray300}"
                                   LineBreakMode="TailTruncation" />
                            <Label Text="{Binding DisplaySubtitle}"
                                   FontSize="18"
                                   TextColor="{StaticResource Gray400}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>


</ContentPage>
