<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="CopilotChatApp.Views.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:services="clr-namespace:CopilotChatApp.Services"
    Title="Sessions">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="🔄" Order="Primary" Priority="-1" Clicked="OnRefreshClicked" />
        <ToolbarItem Text="New chat" Order="Primary" Priority="0" Clicked="OnNewChatClicked" />
        <ToolbarItem Text="Settings" Order="Primary" Priority="1" Clicked="OnSettingsClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" Padding="16" RowSpacing="12">

        <!-- Summary chip: one tappable label per successfully-connected server (OS glyph + name),
             fetched best-effort via server:info for every configured profile in parallel - see
             HomePage.xaml.cs RefreshServerInfoSummary. Tapping one filters the session list down to
             just that server; tapping the same one again clears the filter. Built in code-behind
             (like SettingsPage's profile list) since the number of children changes at runtime. -->
        <Border Grid.Row="0"
                x:Name="ServerInfoBorder"
                IsVisible="False"
                StrokeShape="RoundRectangle 10"
                Stroke="Transparent"
                Padding="12,8"
                BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource Gray900}}">
            <HorizontalStackLayout x:Name="ServerInfoStack" Spacing="14" />
        </Border>

        <!-- Full-text search across session titles AND actual conversation content (server-side,
             see sessionHistory.searchSessions) - titles alone are often the same auto-generated text
             across many sessions, so content search is the useful part here. -->
        <SearchBar Grid.Row="1"
                   x:Name="SearchBarControl"
                   Placeholder="会話の内容やタイトルを検索"
                   TextChanged="OnSearchTextChanged" />

        <!-- Client-side filter only (see HomePage.xaml.cs ApplyArchiveFilter) - no extra server round-trip,
             since RefreshAsync already fetches every session (archived or not) in one shot. -->
        <HorizontalStackLayout Grid.Row="2" Spacing="8" HorizontalOptions="End">
            <Label Text="📦 アーカイブ済みも表示"
                   FontSize="16"
                   TextColor="Gray"
                   VerticalOptions="Center" />
            <Switch x:Name="ShowArchivedSwitch" Toggled="OnShowArchivedToggled" VerticalOptions="Center" />
        </HorizontalStackLayout>

        <Label x:Name="NotConfiguredLabel"
               Grid.Row="3"
               Text="サーバーが未設定です。右上の Settings からサーバーURLとトークンを入力してください。"
               IsVisible="False"
               FontSize="20"
               TextColor="Gray"
               Margin="0,20,0,0" />

        <HorizontalStackLayout Grid.Row="4" Spacing="8">
            <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False" />
            <Label x:Name="LoadingLabel"
                   Text="Connecting to server… this can take up to 30s while waiting for network permission"
                   IsVisible="False"
                   VerticalOptions="Center"
                   FontSize="20"
                   TextColor="Gray" />
        </HorizontalStackLayout>

        <CollectionView x:Name="SessionsView"
                        Grid.Row="5"
                        ItemsSource="{Binding Sessions}"
                        SelectionMode="None">
            <CollectionView.EmptyView>
                <Label Text="過去のセッションはまだありません。「New chat」で始めましょう。" FontSize="20" TextColor="Gray" Margin="0,20,0,0" />
            </CollectionView.EmptyView>
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2" VerticalItemSpacing="12" HorizontalItemSpacing="12" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="services:SessionSummary">
                    <Border StrokeShape="RoundRectangle 14"
                            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                            StrokeThickness="1"
                            Padding="14,12"
                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.08" Radius="8" Offset="0,3" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSessionTapped" CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="4">
                            <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="6">
                                <Label Text="📦 Archived" FontSize="17" TextColor="{StaticResource Gray400}" IsVisible="{Binding Archived}" />
                                <!-- PBI-027: at-a-glance badges for the Orchestrator screen's parent/child
                                     relationships (🎼 theme: Conductor = has spawned children under it,
                                     Player = was itself spawned as a child of another session). Both can
                                     theoretically be true at once (a child that itself spawned grandchildren). -->
                                <Label Text="🎼 Conductor" FontSize="17" TextColor="{StaticResource Gray400}" IsVisible="{Binding IsOrchestratorParent}" />
                                <Label Text="🎻 Player" FontSize="17" TextColor="{StaticResource Gray400}" IsVisible="{Binding IsOrchestratorChild}" />
                            </HorizontalStackLayout>
                            <!-- "..." card menu: rename (label) / archive toggle. A Label with its own
                                 TapGestureRecognizer (not a Button) to match the existing tap-target
                                 pattern used elsewhere in this app (e.g. the message bubble's "🔎 テキスト
                                 選択" row) - MAUI routes the tap to this innermost recognizer rather than
                                 bubbling it to the Border's own OnSessionTapped. -->
                            <Label Grid.Row="0"
                                   Grid.Column="1"
                                   Text="⋯"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   Padding="10,0"
                                   TextColor="{StaticResource Gray400}"
                                   VerticalOptions="Start">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnCardMenuTapped" CommandParameter="{Binding .}" />
                                </Label.GestureRecognizers>
                            </Label>
                            <Label Grid.Row="1"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="2"
                                   Text="{Binding DisplayTitle}"
                                   FontAttributes="Bold"
                                   FontSize="21"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="2" />
                            <Label Grid.Row="2"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="2"
                                   Text="{Binding FolderName, StringFormat='📁 {0}'}"
                                   FontSize="17"
                                   TextColor="{StaticResource Gray300}"
                                   LineBreakMode="TailTruncation" />
                            <!-- Which configured server this session came from, with an OS glyph (see
                                 SessionSummary.ProfileDisplayLabel / HomePage's aggregated multi-server list) -
                                 harmless to always show even with a single profile configured, and tells
                                 sessions from different servers apart once more than one is. -->
                            <Label Grid.Row="3"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="2"
                                   Text="{Binding ProfileDisplayLabel}"
                                   IsVisible="{Binding ProfileName, Converter={StaticResource StringNotEmptyConverter}}"
                                   FontSize="17"
                                   TextColor="{StaticResource Gray300}"
                                   LineBreakMode="TailTruncation" />
                            <Label Grid.Row="4"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="2"
                                   Text="{Binding DisplaySubtitle}"
                                   FontSize="18"
                                   TextColor="{StaticResource Gray400}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>


</ContentPage>
