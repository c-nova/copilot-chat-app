<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="CopilotChatApp.Views.OrchestratorPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:CopilotChatApp.Models"
    xmlns:vm="clr-namespace:CopilotChatApp.ViewModels"
    xmlns:idk="clr-namespace:Indiko.Maui.Controls.Markdown;assembly=Indiko.Maui.Controls.Markdown"
    Title="🎼 Orchestrator">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="＋ 子セッション" Order="Primary" Priority="0" Clicked="OnAddChildClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="3*,Auto,Auto,Auto,2*" Padding="0">

        <!-- Main session - the only pane a human ever types into directly. Child sessions below are
             driven exclusively by this session's AI (run_turn_on_session/spawn_session) - see
             PBI.md's PBI-025 design notes for why there's no input box on the child panes. -->
        <CollectionView x:Name="MainMessagesView"
                Grid.Row="0"
                        Margin="8"
                ItemsUpdatingScrollMode="KeepScrollOffset"
                        ItemsSource="{Binding MainChat.Messages}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ChatMessage">
                    <Grid Padding="4" IsVisible="{Binding IsTool, Converter={StaticResource InvertedBoolConverter}}">
                        <Border Padding="10,8"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="{Binding ., Converter={StaticResource MessageToBubbleColorConverter}}"
                                HorizontalOptions="{Binding IsUser, Converter={StaticResource BoolToAlignConverter}}"
                                MaximumWidthRequest="480">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="🤖 Message from other Agent"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="#8B5E00"
                                       IsVisible="{Binding IsFromOtherSession}" />
                                <idk:MarkdownView MarkdownText="{Binding Text}"
                                                   TextFontSize="{DynamicResource ChatFontSize}"
                                                   CodeBlockFontSize="{DynamicResource ChatFontSize}"
                                                   H1Color="#1A1A1A"
                                                   H2Color="#1A1A1A"
                                                   H3Color="#1A1A1A"
                                                   H4Color="#1A1A1A"
                                                   H5Color="#1A1A1A"
                                                   H6Color="#1A1A1A">
                                    <idk:MarkdownView.CodeBlockFontFace>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="iOS, MacCatalyst" Value="Courier" />
                                            <On Platform="WinUI" Value="Consolas" />
                                            <On Platform="Android" Value="monospace" />
                                        </OnPlatform>
                                    </idk:MarkdownView.CodeBlockFontFace>
                                </idk:MarkdownView>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Composer for the main session only - mirrors MainPage's Editor (multi-line, Cmd/Ctrl+Enter
             to submit - see OrchestratorPage.xaml.cs's SetUpSubmitShortcut) so behavior matches the
             normal chat screen. -->
        <Grid Grid.Row="1"
              ColumnDefinitions="*,Auto"
              Padding="8,4"
              ColumnSpacing="8">
            <Editor x:Name="InputEditor"
                    Grid.Column="0"
                    Text="{Binding MainChat.InputText}"
                    Placeholder="メインセッションに指示する..."
                    AutoSize="TextChanges"
                    MinimumHeightRequest="44"
                    MaxLength="8000" />
            <Button Grid.Column="1" Text="送信" Command="{Binding MainChat.SendCommand}" VerticalOptions="Center" />
        </Grid>

        <!-- Sending status indicator - same as MainPage's (see PBI-015): shown from Send until the
             turn is fully finalized, not just until the first visible activity. -->
        <HorizontalStackLayout Grid.Row="2"
                               IsVisible="{Binding MainChat.IsSending}"
                               Spacing="6"
                               Margin="12,0,12,4">
            <ActivityIndicator IsRunning="{Binding MainChat.IsSending}"
                               Color="Gray"
                               WidthRequest="14"
                               HeightRequest="14"
                               VerticalOptions="Center" />
            <Label Text="Copilot is working…"
                   FontSize="14"
                   FontAttributes="Italic"
                   TextColor="Gray"
                   VerticalOptions="Center" />
        </HorizontalStackLayout>

        <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Padding="8,6,8,2" BackgroundColor="{AppThemeBinding Light=#F2F2F7, Dark=#1C1C1E}">
            <Label Grid.Column="0"
                   Text="{Binding Children.Count, StringFormat='🧩 子セッション ({0})'}"
                   FontAttributes="Bold"
                   VerticalOptions="Center" />
        </Grid>

        <!-- Child session panes: read-only logs, ordered oldest-spawned first. Each pane is its own
             non-scrolling stack (BindableLayout, not CollectionView) so nesting it inside this outer
             ScrollView doesn't create the classic "scrollable inside scrollable" gesture conflict. -->
        <ScrollView x:Name="ChildrenScrollView" Grid.Row="4">
            <VerticalStackLayout Spacing="4" Padding="8" BindableLayout.ItemsSource="{Binding Children}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:ChildSessionPaneViewModel">
                        <Border Padding="8" Margin="0,0,0,8" StrokeShape="RoundRectangle 10" BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#2C2C2E}">
                            <VerticalStackLayout Spacing="6">
                                <HorizontalStackLayout Spacing="6">
                                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" WidthRequest="14" HeightRequest="14" Color="Gray" />
                                    <Label Text="{Binding Title}" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding Session.ProfileDisplayLabel}" FontSize="11" TextColor="Gray" />
                                    <Label Text="作業中..." FontSize="11" TextColor="Gray" IsVisible="{Binding IsBusy}" />
                                </HorizontalStackLayout>
                                <VerticalStackLayout Spacing="4" BindableLayout.ItemsSource="{Binding Messages}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="models:ChatMessage">
                                            <Border Padding="8,6"
                                                    StrokeShape="RoundRectangle 8"
                                                    BackgroundColor="{Binding ., Converter={StaticResource MessageToBubbleColorConverter}}"
                                                    HorizontalOptions="{Binding IsUser, Converter={StaticResource BoolToAlignConverter}}"
                                                    MaximumWidthRequest="420">
                                                <idk:MarkdownView MarkdownText="{Binding Text}"
                                                                   TextFontSize="13"
                                                                   CodeBlockFontSize="13"
                                                                   H1Color="#1A1A1A"
                                                                   H2Color="#1A1A1A"
                                                                   H3Color="#1A1A1A"
                                                                   H4Color="#1A1A1A"
                                                                   H5Color="#1A1A1A"
                                                                   H6Color="#1A1A1A">
                                                    <idk:MarkdownView.CodeBlockFontFace>
                                                        <OnPlatform x:TypeArguments="x:String">
                                                            <On Platform="iOS, MacCatalyst" Value="Courier" />
                                                            <On Platform="WinUI" Value="Consolas" />
                                                            <On Platform="Android" Value="monospace" />
                                                        </OnPlatform>
                                                    </idk:MarkdownView.CodeBlockFontFace>
                                                </idk:MarkdownView>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
